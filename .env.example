# Servidor
PORT=3000
NODE_ENV=production
TZ=America/Sao_Paulo
APP_TIMEZONE=America/Sao_Paulo

# WhatsApp - Evolution API
EVOLUTION_API_URL=https://sua-evolution.url
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=nome-da-instancia
OWNER_PHONE=5512999999999

# LLMs
GROQ_API_KEY=sua-groq-key
GROQ_AUDIO_MODEL=whisper-large-v3-turbo
GEMINI_API_KEY=sua-gemini-key

# OpenRouter (opcional: fallback/modelos mais fortes)
OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=sua-openrouter-key
OPENROUTER_FREE_ONLY=true
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_FREE_FALLBACK_MODEL=deepseek/deepseek-r1:free
OPENROUTER_SITE_URL=https://central-lapaos.oopleb.easypanel.host
OPENROUTER_APP_NAME=Lapa OS

# Redis
REDIS_URL=redis://default:senha@central_redis:6379

# MySQL - Lapa OS v2
DB_DRIVER=mysql
MYSQL_HOST=2.24.78.88
MYSQL_PORT=3306
MYSQL_DATABASE=lapaos
MYSQL_USER=app_lapa
MYSQL_PASSWORD=troque-esta-senha
MYSQL_CONNECTION_LIMIT=100
MYSQL_CONNECT_TIMEOUT_MS=10000
MYSQL_SSL=false

# Opcional. Deixe vazio quando usar MYSQL_*.
# Se usar URL, a senha precisa estar URL-encoded.
DATABASE_URL=
